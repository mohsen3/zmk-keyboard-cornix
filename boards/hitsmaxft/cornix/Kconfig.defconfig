# Cornix board configuration

# Copyright (c) 2020 The ZMK Contributors
# SPDX-License-Identifier: MIT

## Peripheral devices (left side and phantom right for dongle mode)
if BOARD_CORNIX_LEFT || BOARD_CORNIX_PH_RIGHT

config ZMK_SPLIT_ROLE_CENTRAL
    default n

config ZMK_SPLIT_BLE_ROLE_CENTRAL
	default n

# Optimized keyboard debouncing for low latency
# Reduced press from 3ms to 2ms for faster response with stability
# Release kept at 5ms for stability
config ZMK_KSCAN_DEBOUNCE_PRESS_MS
    default 2
config ZMK_KSCAN_DEBOUNCE_RELEASE_MS
    default 5

endif # BOARD_CORNIX_LEFT || BOARD_CORNIX_PH_RIGHT

## Main device (right side)
if BOARD_CORNIX_RIGHT || BOARD_CORNIX_DONGLE

config ZMK_KEYBOARD_NAME
	default "Cornix"

if USB

config USB_NRFX
    default y

config USB_DEVICE_STACK
    default y

endif # USB
config ZMK_SPLIT_ROLE_CENTRAL
    default y

config ZMK_SPLIT_BLE_ROLE_CENTRAL
	default y

config ZMK_SPLIT_BLE_CENTRAL_BATTERY_LEVEL_FETCHING
	default y

config ZMK_SPLIT_BLE_CENTRAL_BATTERY_LEVEL_PROXY
	default y

endif # BOARD_CORNIX_RIGHT || BOARD_CORNIX_DONGLE

# Common options for all board variants
if BOARD_CORNIX_LEFT || BOARD_CORNIX_DONGLE || BOARD_CORNIX_RIGHT || BOARD_CORNIX_PH_RIGHT


config BOARD_CORNIX_CHARGER
    default y

config ZMK_SPLIT
	default y

config ZMK_BLE
	default y

## disable rgb by default
config ZMK_RGB_UNDERGLOW
	default n
config ZMK_RGB_UNDERGLOW_EXT_POWER
	default n

endif # BOARD_CORNIX_LEFT || BOARD_CORNIX_RIGHT || BOARD_CORNIX_PH_RIGHT || BOARD_CORNIX_DONGLE


# vim: set ft=kconfig:
